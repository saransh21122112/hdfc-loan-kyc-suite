# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME="HDFC KYC Engine"
API_VERSION="v1"
DEBUG=false

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://kyc:kyc_password@localhost:5432/kyc_db

# ── Object Storage (MinIO — self-hosted S3, satisfies RBI data residency) ────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=kyc-documents
MINIO_SECURE=false

# ── Redis (Celery task queue) ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT Auth ──────────────────────────────────────────────────────────────────
# MUST be changed before any bank deployment
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_64_BYTE_HEX_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Encryption (AES-256 for PII at rest — RBI IT framework requirement) ───────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_THIS_TO_A_FERNET_KEY

# ── OCR Backend ───────────────────────────────────────────────────────────────
# "tesseract"  — default, works out of the box (brew install tesseract)
# "paddleocr"  — better accuracy for Hindi/regional scripts, requires GPU
OCR_BACKEND=tesseract

# ── OpenAI API ────────────────────────────────────────────────────────────────
# IMPORTANT — RBI data residency rule:
# Use ONLY for non-PII tasks: sales collateral, code generation, internal docs.
# NEVER send customer PAN / Aadhaar / bank statement data to OpenAI endpoints.
# All document processing stays on-premise via Tesseract / LayoutLM.
OPENAI_API_KEY=your-openai-api-key-here
